# ═══════════════════════════════════════════════════════════
#  CONFLUENCE AI CHATBOT — CONFIGURATION
#  Change AI_PROVIDER to switch between models instantly
# ═══════════════════════════════════════════════════════════

# ── AI Provider (change this ONE line to switch models) ──
# Options: groq | openai | anthropic | google | ollama
AI_PROVIDER=groq

# ── Model name for each provider ─────────────────────────
# groq     → llama-3.1-70b-versatile  (FREE)
# openai   → gpt-4o
# anthropic→ claude-3-5-sonnet-20241022
# google   → gemini-1.5-pro
# ollama   → llama3.2  (local, fully free)
AI_MODEL=llama-3.1-70b-versatile

# ── API Keys (only fill the one you are using) ───────────
GROQ_API_KEY=your_groq_api_key_here
OPENAI_API_KEY=your_openai_key_here
ANTHROPIC_API_KEY=your_anthropic_key_here
GOOGLE_API_KEY=your_google_key_here

# ── Confluence Settings ───────────────────────────────────
CONFLUENCE_URL=https://yourcompany.atlassian.net
CONFLUENCE_USERNAME=your@email.com
CONFLUENCE_API_TOKEN=your_confluence_api_token
CONFLUENCE_SPACE_KEY=YOUR_SPACE_KEY

# ── Vector Database ───────────────────────────────────────
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=confluence_docs

# ── Embedding Model ───────────────────────────────────────
# We always use a free embedding model regardless of AI provider
# sentence-transformers runs locally — completely free forever
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ── App Settings ─────────────────────────────────────────
APP_NAME=Confluence AI Assistant
APP_SECRET_KEY=change-this-to-random-string-in-production
DEBUG=true
PORT=8000

# ── Sync Settings ────────────────────────────────────────
# How many pages to sync at once
SYNC_BATCH_SIZE=10
# Maximum characters per chunk
CHUNK_SIZE=1000
# Overlap between chunks (for context continuity)
CHUNK_OVERLAP=200
